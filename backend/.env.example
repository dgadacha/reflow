# Copier en `.env` et remplir.

# Obligatoire — clé API Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Optionnel — surcharges
REFLOW_MODEL=claude-opus-4-8
REFLOW_SUBTITLE_LANGS=en,fr
REFLOW_FREE_QUOTA=3
REFLOW_PRO_QUOTA=30
REFLOW_WHISPER=false
REFLOW_CORS_ORIGINS=http://localhost:4321

# Mode dev : cache les résultats par vidéo + ignore le quota (tests sans coût API).
REFLOW_DEV_MODE=false
